generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String         @id @default(cuid())
  phoneE164      String         @unique
  displayName    String?
  /// Single profile photo as a data URL (JPEG). MVP storage until cloud uploads.
  avatarDataUrl  String?        @db.Text
  intent         String?
  city           String?
  energy         String?
  aboutLine      String?
  bio            String?
  promptsJson        Json?
  questionnaireJson  Json?
  onboardedAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  refreshTokens  RefreshToken[]
  likesFrom      Like[]         @relation("LikesFrom")
  likesTo        Like[]         @relation("LikesTo")
}

model Like {
  id         String   @id @default(cuid())
  fromUserId String
  toUserId   String
  createdAt  DateTime @default(now())
  fromUser   User     @relation("LikesFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser     User     @relation("LikesTo", fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([fromUserId, toUserId])
  @@index([toUserId])
}

model Match {
  id        String   @id @default(cuid())
  userAId   String
  userBId   String
  createdAt DateTime @default(now())

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
}

model OtpChallenge {
  id          String   @id @default(cuid())
  phoneE164   String
  codeHash    String
  expiresAt   DateTime
  attempts    Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([phoneE164])
}

model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}
