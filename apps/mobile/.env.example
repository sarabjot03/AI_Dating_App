# Copy to .env for local development (never commit .env)
EXPO_PUBLIC_APP_ENV=development
# API base URL only — no /v1, no trailing slash.
# Hosted API (Render): https://your-service.onrender.com
# iOS Simulator + API on Mac: http://127.0.0.1:3000
# Android Emulator + API on Mac: http://10.0.2.2:3000
EXPO_PUBLIC_API_URL=http://127.0.0.1:3000
