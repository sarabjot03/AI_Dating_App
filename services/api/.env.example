APP_ENV=development
PORT=3000
# PostgreSQL — from repo root: docker compose up -d
# Use 127.0.0.1 (not localhost) if you still get auth errors (IPv6 vs IPv4).
# Requires nothing else listening on host port 5432 (see README if you get “port already allocated”).
DATABASE_URL=postgresql://spark:spark@127.0.0.1:5432/spark
# openssl rand -base64 32
JWT_SECRET=replace-with-a-long-random-secret
# OTP provider (MSG91) - required in production for real SMS
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
# Optional override for enterprise/regional endpoint needs
MSG91_OTP_ENDPOINT=https://control.msg91.com/api/v5/otp
# Comma-separated origins for production web clients (Expo web). Mobile apps do not rely on CORS.
CORS_ORIGIN=http://localhost:8081
